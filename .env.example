# Rename this file to .env and fill in your values.
# Place it in the same folder as SOC_Report_Generator.exe.
# This file must NOT be committed to Git (see .gitignore).

DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY_MAIN=app-xxxxxxxxxxxxxxxx
DIFY_API_KEY_SUB1=app-xxxxxxxxxxxxxxxx
DIFY_API_KEY_SUB2=app-xxxxxxxxxxxxxxxx

# ── MA/AR template source ──────────────────────────────────────────────────────
# Where the MA/AR Word templates come from. Default is the copies bundled next to
# the .exe. Set TEMPLATE_SOURCE to pull the latest from the EY SharePoint library
# "GCSOCR / Reporting files templates" instead. Any failure falls back to bundled.
#   bundled      (default) — use the templates shipped with the app
#   feishu                 — download from a Feishu (Lark) Drive folder
#   sharepoint             — download from the online SharePoint library
#   onedrive               — read from a locally synced/mapped copy
#TEMPLATE_SOURCE=feishu

# -- feishu mode --
# App-credential auth (no per-user sign-in). Create a Feishu app, add Drive read
# scopes and publish it; upload the .docx into two Drive folders and share each
# folder with the app as a reader; the folder token is the part after /folder/ in the
# folder URL. FEISHU_APP_SECRET is a secret — bake it into the build before shipping.
# Use larksuite.com for the international (non-China) Lark.
#FEISHU_API_BASE=https://open.feishu.cn/open-apis
#FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
#FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#FEISHU_MA_FOLDER_TOKEN=fldcnxxxxxxxxxxxxxxxxxxxxxx
#FEISHU_AR_FOLDER_TOKEN=fldcnxxxxxxxxxxxxxxxxxxxxxx

# -- sharepoint mode --
# No credential needed: on an internal EY machine the app reuses the sign-in of the
# browser the user is already logged in to SharePoint with. These default to the
# current library; override only if the site or folders move.
#SHAREPOINT_SITE_URL=https://eychinamanaged.sharepoint.cn/sites/GCSOCR
#SHAREPOINT_MA_FOLDER=/sites/GCSOCR/Reporting files templates/1.1 MA整理版
#SHAREPOINT_AR_FOLDER=/sites/GCSOCR/Reporting files templates/1.2 AR整理版/AR updated Verison

# -- onedrive mode (only if you sync the library to a local folder) --
#TEMPLATE_BASE_PATH=C:\Users\<you>\Ernst & Young\GCSOCR - Reporting files templates
#MA_TEMPLATE_SUBPATH=1.1 MA整理版
#AR_TEMPLATE_SUBPATH=1.2 AR整理版/AR updated Verison
